# Copy to .env.local (git-ignored) and fill in your key for real AI planning.
# Without a key, the app runs on the offline mock planner.
# Get a key at https://platform.claude.com
ANTHROPIC_API_KEY=

# --- App password gate (Story 6) -----------------------------------------
# Single shared password protecting ALL pages and API routes (this is a
# single-user app). Set both locally and in the Vercel dashboard. Server-side
# only — never prefixed NEXT_PUBLIC_, never sent to the browser. Leaving this
# BLANK disables the gate (handy for local dev); production must set it.
APP_PASSWORD=
# Secret used to sign the login session cookie (HMAC). Generate a random one, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Hosted key-value store (Story 6, for Vercel) ------------------------
# On Vercel the filesystem is ephemeral, so Google tokens, calendar mapping,
# Granola items, and completions persist in a hosted KV store instead of local
# files. Provision the free KV add-on in the Vercel dashboard (Storage tab) — it
# injects these automatically. Locally you can leave them blank to use files.
# Supports Vercel Marketplace KV names OR native Upstash names:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (or) UPSTASH_REDIS_REST_URL= / UPSTASH_REDIS_REST_TOKEN=

# --- Google Calendar integration (Story 3) -------------------------------
# OAuth client credentials from Google Cloud Console (see docs/google-calendar-setup.md).
# Never commit real values. Without these, the app runs without Google (mock data).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI registered on the OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# Secret used to encrypt stored refresh tokens at rest. Generate a random one, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_SECRET=

# --- Canvas assignments (Story 4) ----------------------------------------
# See docs/canvas-setup.md. The token is the primary source (richer: course
# names, due dates, submission state). The ICS calendar-feed URL is the fallback
# when a token isn't available. Both are secrets — never commit real values.
# Base URL of your Canvas instance, e.g. https://<institution>.instructure.com
CANVAS_BASE_URL=
# Personal access token: Canvas → Account → Settings → "+ New Access Token".
CANVAS_API_TOKEN=
# Fallback only. Canvas → Calendar → "Calendar Feed" (a secret per-user .ics URL).
CANVAS_ICS_URL=

# --- Granola action items (Story 5) --------------------------------------
# See docs/granola-setup.md. Granola's personal API uses a Bearer API key (grn_…)
# generated in Granola → Settings → Connectors → API keys (scope: Personal notes).
# Read server-side only; never commit. Without it, the app runs in Granola demo
# mode (GRANOLA_MOCK=1).
GRANOLA_API_KEY=
# Optional base-URL override (defaults to Granola's personal API):
# GRANOLA_API_BASE=https://public-api.granola.ai/v1
